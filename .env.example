# --- LLM (Groq free tier, OpenAI-compatible) ---
OPENAI_API_KEY=gsk_your_groq_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# --- Google Tasks ---
# 1) https://console.cloud.google.com → enable "Google Tasks API"
# 2) Credentials → Create Credentials → OAuth client ID → Desktop app
# 3) Fill CLIENT_ID / CLIENT_SECRET below
# 4) Run: npm run auth:google → paste refresh_token back here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_TASKLIST_ID=@default

# TASK_SINK=console  # uncomment for in-memory mock (dev only)

# --- App settings ---
TIMEZONE=Asia/Almaty
LOG_LEVEL=info
